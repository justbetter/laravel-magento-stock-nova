{
    "name": "justbetter/laravel-magento-stock-nova",
    "description": "Nova integration for justbetter/laravel-magento-stock",
    "type": "package",
    "license": "MIT",
    "authors": [
        {
            "name": "Vincent Boon",
            "email": "vincent@justbetter.nl",
            "role": "Developer"
        },
        {
            "name": "Ramon Rietdijk",
            "email": "ramon@justbetter.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "bolechen/nova-activitylog": "^0.5.0",
        "justbetter/laravel-magento-stock": "^2.3.4",
        "laravel/framework": "^12.0|^13.0",
        "laravel/nova": "^5.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.11|^11.0",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "JustBetter\\MagentoStockNova\\": "src"
        }
    },
    "scripts": {
        "analyse": "phpstan --memory-limit=256M",
        "style": "pint --test",
        "rector": "rector process --dry-run",
        "quality": [
            "@style",
            "@analyse",
            "@rector"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "JustBetter\\MagentoStockNova\\ServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        }
    ]
}
